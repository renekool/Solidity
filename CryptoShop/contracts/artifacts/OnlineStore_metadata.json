				"addProduct(string,uint256,uint256,uint8)": {
					"details": "Función pública para que el propietario agregue nuevos productos a la tienda.",
					"params": {
						"_category": "Categoría del producto.",
						"_name": "Nombre del producto.",
						"_price": "Precio del producto en tokens STK.",
						"_stock": "Cantidad disponible en inventario."
					}
				},
				"buyProduct(uint256,uint256)": {
					"details": "Función para comprar un producto utilizando tokens STK.",
					"params": {
						"_productId": "ID del producto a comprar.",
						"_quantity": "Cantidad del producto a comprar."
					}
				},
				"buyTokens()": {
					"details": "Función para que los clientes compren tokens enviando Ether. La función es 'payable' para recibir Ether."
				},
				"getProduct(uint256)": {
					"details": "Función pública para obtener información de un producto.",
					"params": {
						"_productId": "ID del producto a consultar."
					},
					"returns": {
						"_0": "product by id"
					}
				},
				"getStoreTokenBalance()": {
					"details": "Función 'view' para obtener el balance de tokens de la tienda.",
					"returns": {
						"_0": "tokenBalance Balance de tokens STK de la tienda."
					}
				},
				"owner()": {
					"details": "Returns the address of the current owner."
				},
				"renounceOwnership()": {
					"details": "Leaves the contract without owner. It will not be possible to call `onlyOwner` functions anymore. Can only be called by the current owner. NOTE: Renouncing ownership will leave the contract without an owner, thereby removing any functionality that is only available to the owner."
				},
				"transferOwnership(address)": {
					"details": "Transfers ownership of the contract to a new account (`newOwner`). Can only be called by the current owner."
				},
				"updateProduct(uint256,string,uint256,uint256,uint8)": {
					"details": "Función pública para actualizar un producto existente.",
					"params": {
						"_category": "Nueva categoría del producto.",
						"_name": "Nuevo nombre del producto.",
						"_price": "Nuevo precio del producto.",
						"_productId": "ID del producto a actualizar.",
						"_stock": "Nuevo stock del producto."
					}
				},
				"weiToEther(uint256)": {
					"details": "Función 'pure' para convertir Wei a Ether.",
					"params": {
						"weiAmount": "Cantidad en Wei."
					},
					"returns": {
						"_0": "etherAmount Cantidad en Ether."
					}
				},
				"withdrawFunds()": {
					"details": "Función para que el propietario retire los Ether recaudados por venta de tokens."
				},
				"withdrawTokens()": {
					"details": "Función para que el propietario retire los tokens acumulados por venta de productos."
